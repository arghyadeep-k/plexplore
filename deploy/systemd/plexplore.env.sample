# Copy to /etc/plexplore/plexplore.env and adjust values for your host.

# HTTP bind
APP_HTTP_LISTEN_ADDR=0.0.0.0:8080

# Persistent state location (SQLite + spool)
APP_SQLITE_PATH=/var/lib/plexplore/plexplore.db
APP_SPOOL_DIR=/var/lib/plexplore/spool

# Runtime behavior tuning for Pi Zero 2 W
APP_BUFFER_MAX_POINTS=256
APP_BUFFER_MAX_BYTES=262144
APP_FLUSH_INTERVAL=10s
APP_FLUSH_BATCH_SIZE=128
APP_FLUSH_TRIGGER_POINTS=192
APP_FLUSH_TRIGGER_BYTES=196608

# Cookie/proxy security.
# auto: Secure cookies only on HTTPS requests (or trusted forwarded https).
# always: always set Secure cookies (recommended for direct HTTPS only).
# never: never set Secure cookies (local HTTP development only).
APP_COOKIE_SECURE_MODE=auto
# Trust X-Forwarded-Proto only when traffic comes from your own reverse proxy.
APP_TRUST_PROXY_HEADERS=false
# Set true when TLS is terminated upstream and app receives proxied HTTP.
APP_EXPECT_TLS_TERMINATION=false

# In-process rate limiting for login/admin-sensitive routes.
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_LOGIN_MAX_REQUESTS=10
APP_RATE_LIMIT_LOGIN_WINDOW=1m
APP_RATE_LIMIT_ADMIN_MAX_REQUESTS=30
APP_RATE_LIMIT_ADMIN_WINDOW=1m

# Spool durability tuning
APP_SPOOL_SEGMENT_MAX_BYTES=4194304
APP_SPOOL_FSYNC_MODE=balanced
APP_SPOOL_FSYNC_INTERVAL=2s
APP_SPOOL_FSYNC_BYTE_THRESHOLD=65536

# HTTP timeouts
APP_READ_TIMEOUT_SECONDS=5
APP_WRITE_TIMEOUT_SECONDS=10
APP_IDLE_TIMEOUT_SECONDS=30
